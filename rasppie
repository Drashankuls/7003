import requests
import time
import csv
from datetime import datetime
import pytz

# List of stocks to track
symbols = ["AAPL", "TSLA", "MSFT", "AMZN"]

# PST timezone
pst = pytz.timezone("America/Los_Angeles")

# Create rapid.csv with header if not exists
try:
    with open("rapid.csv", "x", newline="") as f:
        writer = csv.writer(f)
        writer.writerow(["Time_PST", "Symbol", "Last", "Bid", "Ask", "Mark"])
except FileExistsError:
    pass  # File already exists

while True:
    now = datetime.now(pst).strftime("%Y-%m-%d %H:%M:%S")

    for symbol in symbols:
        try:
            url = "https://api.robinhood.com/quotes/{}/".format(symbol)
            data = requests.get(url).json()

            last_trade = float(data["last_trade_price"])
            bid = float(data["bid_price"])
            ask = float(data["ask_price"])
            mark_price = (bid + ask) / 2

            # Append to rapid.csv
            with open("rapid.csv", "a", newline="") as f:
                writer = csv.writer(f)
                writer.writerow([now, symbol, last_trade, bid, ask, round(mark_price, 4)])

            print(now, symbol, "Last:", last_trade, "Bid:", bid, "Ask:", ask, "Mark:", round(mark_price, 4))

        except Exception as e:
            print("Error with", symbol, ":", e)

    time.sleep(2)
