from flask import Flask, jsonify, request
import requests
import time

app = Flask(__name__)

YAHOO_GAINERS_URL = "https://query1.finance.yahoo.com/v1/finance/screener/predefined/saved"
YAHOO_CHART_URL = "https://query1.finance.yahoo.com/v8/finance/chart/"
ROBINHOOD_QUOTES_URL = "https://api.robinhood.com/quotes/"

############################################################
# FETCH TOP 100 GAINERS (YAHOO)
############################################################
def get_top_gainers_symbols():
    params = {"scrIds": "day_gainers", "count": 100}
    try:
        r = requests.get(YAHOO_GAINERS_URL, params=params, timeout=10)
        data = r.json()
        result = data.get("finance", {}).get("result", [])
        if not result:
            return []
        quotes = result[0].get("quotes", [])
        symbols = []
        for q in quotes:
            s = q.get("symbol")
            if s:
                symbols.append(s)
        return symbols
    except:
        return []

############################################################
# FETCH ROBINHOOD QUOTES (BID/ASK/LAST/VOLUME)
############################################################
def get_robinhood_quotes(symbols):
    if not symbols:
        return {}
    joined = ",".join(symbols)
    params = {"symbols": joined}
    out = {}
    try:
        r = requests.get(ROBINHOOD_QUOTES_URL, params=params, timeout=10)
        data = r.json()
        results = data.get("results", [])
        for q in results:
            if not q:
                continue
            symbol = q.get("symbol")
            if not symbol:
                continue
            try:
                last = q.get("last_trade_price")
                bid = q.get("bid_price")
                ask = q.get("ask_price")
                vol = q.get("volume")

                if last is not None: last = float(last)
                if bid is not None: bid = float(bid)
                if ask is not None: ask = float(ask)
                if vol is not None: vol = int(vol)

                out[symbol] = {
                    "last": last,
                    "bid": bid,
                    "ask": ask,
                    "volume_rt": vol
                }
            except:
                continue
        return out
    except:
        return {}

############################################################
# FETCH 1-MINUTE CANDLES (YAHOO)
############################################################
def get_yahoo_candles(symbol):
    url = YAHOO_CHART_URL + symbol
    params = {"interval": "1m", "range": "1d"}
    try:
        r = requests.get(url, params=params, timeout=10)
        data = r.json()
        result = data.get("chart", {}).get("result", [])
        if not result:
            return None
        res0 = result[0]
        timestamps = res0.get("timestamp", [])
        quote = res0.get("indicators", {}).get("quote", [{}])[0]
        closes = quote.get("close", [])
        volumes = quote.get("volume", [])
        if not timestamps or not closes or not volumes:
            return None
        return {"closes": closes, "volumes": volumes}
    except:
        return None

############################################################
# DELTA + VOLUME CALCULATIONS
############################################################
def compute_delta(closes, minutes_back):
    try:
        if closes is None: return None
        n = len(closes)
        if n < minutes_back + 1: return None
        last = closes[-1]
        ref = closes[-(minutes_back + 1)]
        if last is None or ref is None: return None
        return float(last) - float(ref)
    except:
        return None

def compute_volume_window(volumes, minutes_back):
    try:
        if volumes is None: return None
        n = len(volumes)
        if n < minutes_back: return None
        total = 0
        for v in volumes[-minutes_back:]:
            if v is None:
                return None
            total += int(v)
        return total
    except:
        return None

############################################################
# BUILD FINAL ROWS
############################################################
def build_rows():
    symbols = get_top_gainers_symbols()
    quotes = get_robinhood_quotes(symbols)
    rows = []

    for symbol in symbols:
        q = quotes.get(symbol)
        if not q:
            continue

        last = q.get("last")
        bid = q.get("bid")
        ask = q.get("ask")
        vol_rt = q.get("volume_rt")

        if last is None or bid is None or ask is None:
            continue

        spread = ask - bid

        candles = get_yahoo_candles(symbol)
        if not candles:
            continue

        closes = candles["closes"]
        volumes = candles["volumes"]

        d1 = compute_delta(closes, 1)
        d2 = compute_delta(closes, 2)
        d3 = compute_delta(closes, 3)
        d5 = compute_delta(closes, 5)
        d10 = compute_delta(closes, 10)
        d15 = compute_delta(closes, 15)
        d30 = compute_delta(closes, 30)

        v1 = compute_volume_window(volumes, 1)
        v3 = compute_volume_window(volumes, 3)
        v5 = compute_volume_window(volumes, 5)

        required = [d1, d2, d3, d5, d10, d15, d30, v1, v3, v5]
        missing = False
        for x in required:
            if x is None:
                missing = True
                break
        if missing:
            continue

        rows.append({
            "symbol": symbol,
            "last": last,
            "bid": bid,
            "ask": ask,
            "spread": spread,
            "d1": d1,
            "d2": d2,
            "d3": d3,
            "d5": d5,
            "d10": d10,
            "d15": d15,
            "d30": d30,
            "v1": v1,
            "v3": v3,
            "v5": v5,
            "volume_rt": vol_rt
        })

    return rows

