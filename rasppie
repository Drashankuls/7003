from flask import Flask, render_template, jsonify
import requests
import time

app = Flask(__name__)

YAHOO_GAINERS_URL = "https://query1.finance.yahoo.com/v1/finance/screener/predefined/saved"
YAHOO_CHART_URL = "https://query1.finance.yahoo.com/v8/finance/chart/"
ROBINHOOD_QUOTES_URL = "https://api.robinhood.com/quotes/"

def get_top_gainers_symbols():
    params = {
        "scrIds": "day_gainers",
        "count": 100
    }
    try:
        r = requests.get(YAHOO_GAINERS_URL, params=params, timeout=10)
        data = r.json()
        result = data.get("finance", {}).get("result", [])
        if not result:
            return []
        quotes = result[0].get("quotes", [])
        symbols = []
        for q in quotes:
            symbol = q.get("symbol")
            if symbol:
                symbols.append(symbol)
        return symbols
    except Exception:
        return []

def get_robinhood_quotes(symbols):
    if not symbols:
        return {}
    joined = ",".join(symbols)
    params = {"symbols": joined}
    try:
        r = requests.get(ROBINHOOD_QUOTES_URL, params=params, timeout=10)
        data = r.json()
        results = data.get("results", [])
        out = {}
        for q in results:
            if not q:
                continue
            symbol = q.get("symbol")
            if not symbol:
                continue
            try:
                last = q.get("last_trade_price")
                bid = q.get("bid_price")
                ask = q.get("ask_price")
                volume = q.get("volume")
                if last is not None:
                    last = float(last)
                if bid is not None:
                    bid = float(bid)
                if ask is not None:
                    ask = float(ask)
                if volume is not None:
                    volume = int(volume)
                out[symbol] = {
                    "last": last,
                    "bid": bid,
                    "ask": ask,
                    "volume": volume
                }
            except Exception:
                continue
        return out
    except Exception:
        return {}

def get_yahoo_candles(symbol):
    url = YAHOO_CHART_URL + symbol
    params = {
        "interval": "1m",
        "range": "1d"
    }
    try:
        r = requests.get(url, params=params, timeout=10)
        data = r.json()
        result = data.get("chart", {}).get("result", [])
        if not result:
            return None
        res0 = result[0]
        timestamps = res0.get("timestamp", [])
        indicators = res0.get("indicators", {})
        quote_list = indicators.get("quote", [])
        if not quote_list:
            return None
        quote = quote_list[0]
        closes = quote.get("close", [])
        volumes = quote.get("volume", [])
        if not timestamps or not closes or not volumes:
            return None
        return {
            "timestamps": timestamps,
            "closes": closes,
            "volumes": volumes
        }
    except Exception:
        return None

def compute_delta(closes, minutes_back):
    try:
        if closes is None:
            return None
        n = len(closes)
        if n < minutes_back + 1:
            return None
        last = closes[-1]
        ref = closes[-(minutes_back + 1)]
        if last is None or ref is None:
            return None
        return float(last) - float(ref)
    except Exception:
        return None

def compute_volume_window(volumes, minutes_back):
    try:
        if volumes is None:
            return None
        n = len(volumes)
        if n < minutes_back:
            return None
        window = volumes[-minutes_back:]
        total = 0
        for v in window:
            if v is None:
                return None
            total += int(v)
        return total
    except Exception:
        return None

def build_rows():
    symbols = get_top_gainers_symbols()
    if not symbols:
        return []

    quotes = get_robinhood_quotes(symbols)
    rows = []

    for symbol in symbols:
        q = quotes.get(symbol)
        if not q:
            continue

        last = q.get("last")
        bid = q.get("bid")
        ask = q.get("ask")
        volume_rt = q.get("volume")

        if last is None or bid is None or ask is None:
            continue

        spread = ask - bid

        candles = get_yahoo_candles(symbol)
        if not candles:
            continue

        closes = candles.get("closes")
        volumes = candles.get("volumes")

        d1 = compute_delta(closes, 1)
        d2 = compute_delta(closes, 2)
        d3 = compute_delta(closes, 3)
        d5 = compute_delta(closes, 5)
        d10 = compute_delta(closes, 10)
        d15 = compute_delta(closes, 15)
        d30 = compute_delta(closes, 30)

        v1 = compute_volume_window(volumes, 1)
        v3 = compute_volume_window(volumes, 3)
        v5 = compute_volume_window(volumes, 5)

        required = [d1, d2, d3, d5, d10, d15, d30, v1, v3, v5]
        missing = False
        for x in required:
            if x is None:
                missing = True
                break
        if missing:
            continue

        row = {
            "symbol": symbol,
            "last": last,
            "bid": bid,
            "ask": ask,
            "spread": spread,
            "d1": d1,
            "d2": d2,
            "d3": d3,
            "d5": d5,
            "d10": d10,
            "d15": d15,
            "d30": d30,
            "v1": v1,
            "v3": v3,
            "v5": v5,
            "volume_rt": volume_rt
        }
        rows.append(row)

    return rows

@app.route("/")
def index():
    return render_template("dashboard.html")

@app.route("/data")
def data():
    rows = build_rows()
    return jsonify({"rows": rows, "timestamp": int(time.time())})

if __name__ == "__main__":
    app.run(host="0.0.0.0", port=5000, debug=False)
