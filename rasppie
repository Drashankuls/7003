from flask import Flask, render_template_string
import requests
import pytz
from datetime import datetime, time
import math
import csv
import os

app = Flask(__name__)

pst = pytz.timezone("America/Los_Angeles")

# List your stocks here
symbols = ["AAPL", "TSLA", "MSFT", "AMZN"]

# State per symbol
state = {}
for s in symbols:
    state[s] = {
        "prev": None,
        "last_swing_time": None,
        "last_swing_type": None,
        "baseline_price": None,
        "baseline_time": None
    }

def safe(value):
    if value is None:
        return "null"
    return value

def get_today_630_pst(now_pst):
    d = now_pst.date()
    six_thirty_naive = datetime(d.year, d.month, d.day, 6, 30, 0)
    return pst.localize(six_thirty_naive)

def get_csv_filename(now_pst):
    d = now_pst.date()
    return "swing_log_%04d%02d%02d.csv" % (d.year, d.month, d.day)

def ensure_csv_header(filename):
    if not os.path.exists(filename):
        with open(filename, "w") as f:
            writer = csv.writer(f)
            writer.writerow([
                "timestamp",
                "symbol",
                "last",
                "ask",
                "bid",
                "spread",
                "swing_type",
                "swing_time",
                "baseline_price",
                "baseline_time",
                "change_since_630",
                "slope_deg"
            ])

HTML_PAGE = """
<!DOCTYPE html>
<html>
<head>
    <title>Live Stock Table</title>
    <meta http-equiv="refresh" content="2">
    <style>
        body { background:#111; color:white; font-family:Arial; }
        table { border-collapse: collapse; width: 95%; margin-top:20px; }
        th, td { border:1px solid #444; padding:8px; text-align:center; }
        th { background:#222; }
        tr:nth-child(even) { background:#1a1a1a; }
    </style>
</head>
<body>
    <h2>Live Stock Prices</h2>
    <table>
        <tr>
            <th>Symbol</th>
            <th>Last</th>
            <th>Ask</th>
            <th>Bid</th>
            <th>Spread</th>
            <th>Last Swing (ago)</th>
            <th>Swing Type</th>
            <th>Δ Since 06:30</th>
            <th>Slope (deg)</th>
        </tr>
        {% for row in rows %}
        <tr>
            <td>{{ row.symbol }}</td>
            <td>{{ row.last }}</td>
            <td>{{ row.ask }}</td>
            <td>{{ row.bid }}</td>
            <td>{{ row.spread }}</td>
            <td>{{ row.swing_ago }}</td>
            <td>{{ row.swing_type_html|safe }}</td>
            <td>{{ row.change_since_630 }}</td>
            <td>{{ row.slope_deg }}</td>
        </tr>
        {% endfor %}
    </table>
</body>
</html>
"""

@app.route("/")
def index():
    rows = []
    now = datetime.now(pst)
    six_thirty = get_today_630_pst(now)
    csv_file = get_csv_filename(now)
    ensure_csv_header(csv_file)

    for symbol in symbols:
        try:
            url = "https://api.robinhood.com/quotes/{}/".format(symbol)
            data = requests.get(url).json()

            last_raw = data.get("last_trade_price")
            ask_raw = data.get("ask_price")
            bid_raw = data.get("bid_price")

            if last_raw is None or ask_raw is None or bid_raw is None:
                last_price = None
                ask_price = None
                bid_price = None
                spread = None
            else:
                last_price = float(last_raw)
                ask_price = float(ask_raw)
                bid_price = float(bid_raw)
                spread = ask_price - bid_price

            prev = state[symbol]["prev"]
            old_swing_type = state[symbol]["last_swing_type"]
            swing_type = old_swing_type
            swing_time = state[symbol]["last_swing_time"]
            baseline_price = state[symbol]["baseline_price"]
            baseline_time = state[symbol]["baseline_time"]

            # Set baseline: first reading after 06:30 if not set yet
            if last_price is not None and baseline_price is None and now >= six_thirty:
                baseline_price = last_price
                baseline_time = now

            # Swing detection only if valid price and prev exists
            if last_price is not None and prev is not None:
                if last_price > prev and swing_type != "LOW":
                    swing_type = "LOW"
                    swing_time = now
                elif last_price < prev and swing_type != "HIGH":
                    swing_type = "HIGH"
                    swing_time = now

            # Save state
            state[symbol]["prev"] = last_price
            state[symbol]["last_swing_type"] = swing_type
            state[symbol]["last_swing_time"] = swing_time
            state[symbol]["baseline_price"] = baseline_price
            state[symbol]["baseline_time"] = baseline_time

            # How long ago swing
            if swing_time is None:
                swing_ago = "null"
            else:
                diff = (now - swing_time).total_seconds()
                if diff < 60:
                    swing_ago = str(int(diff)) + " sec"
                else:
                    swing_ago = str(int(diff / 60)) + " min"

            # Change since 06:30
            if last_price is not None and baseline_price is not None:
                change_since_630 = last_price - baseline_price
            else:
                change_since_630 = None

            # Slope angle (deg) from baseline
            if (last_price is not None and baseline_price is not None and
                    baseline_price > 0 and baseline_time is not None):
                t_sec = (now - baseline_time).total_seconds()
                if t_sec > 0:
                    pct_change = (last_price - baseline_price) / baseline_price * 100.0
                    slope_rad = math.atan(pct_change / t_sec)
                    slope_deg = slope_rad * 180.0 / math.pi
                else:
                    slope_deg = None
            else:
                slope_deg = None

            # Color-coded swing type
            if swing_type == "LOW":
                swing_type_html = '<span style="color:lime">LOW</span>'
            elif swing_type == "HIGH":
                swing_type_html = '<span style="color:red">HIGH</span>'
            else:
                swing_type_html = "null"

            # Prepare display values
            disp_last = safe(round(last_price, 4) if last_price is not None else None)
            disp_ask = safe(round(ask_price, 4) if ask_price is not None else None)
            disp_bid = safe(round(bid_price, 4) if bid_price is not None else None)
            disp_spread = safe(round(spread, 4) if spread is not None else None)
            disp_change = safe(round(change_since_630, 4) if change_since_630 is not None else None)
            disp_slope = safe(round(slope_deg, 4) if slope_deg is not None else None)

            rows.append({
                "symbol": symbol,
                "last": disp_last,
                "ask": disp_ask,
                "bid": disp_bid,
                "spread": disp_spread,
                "swing_ago": safe(swing_ago),
                "swing_type_html": swing_type_html,
                "change_since_630": disp_change,
                "slope_deg": disp_slope
            })

            # CSV logging: only when a NEW swing happens
            if swing_type is not None and swing_type != old_swing_type and swing_time is not None:
                with open(csv_file, "a") as f:
                    writer = csv.writer(f)
                    writer.writerow([
                        now.isoformat(),
                        symbol,
                        last_price if last_price is not None else "",
                        ask_price if ask_price is not None else "",
                        bid_price if bid_price is not None else "",
                        spread if spread is not None else "",
                        swing_type,
                        swing_time.isoformat(),
                        baseline_price if baseline_price is not None else "",
                        baseline_time.isoformat() if baseline_time is not None else "",
                        change_since_630 if change_since_630 is not None else "",
                        slope_deg if slope_deg is not None else ""
                    ])

        except Exception:
            rows.append({
                "symbol": symbol,
                "last": "null",
                "ask": "null",
                "bid": "null",
                "spread": "null",
                "swing_ago": "null",
                "swing_type_html": "null",
                "change_since_630": "null",
                "slope_deg": "null"
            })

    return render_template_string(HTML_PAGE, rows=rows)

if __name__ == "__main__":
    app.run(host="0.0.0.0", port=5000)
