<script>
var dataRows = [];
var sortKey = null;
var sortDir = 1;

function fetchData(){
    var xhr = new XMLHttpRequest();
    xhr.open("GET","/data?_="+new Date().getTime(),true);
    xhr.onreadystatechange=function(){
        if(xhr.readyState===4 && xhr.status===200){
            var d = JSON.parse(xhr.responseText);
            dataRows = d.rows;
            document.getElementById("last-update").innerHTML = "Last update: " + new Date(d.timestamp*1000).toLocaleTimeString();
            render();
        }
    };
    xhr.send();
}

function render(){
    var tb = document.querySelector("#tbl tbody");
    tb.innerHTML = "";

    var arr = dataRows.slice(0);

    if(sortKey){
        arr.sort(function(a,b){
            var va=a[sortKey], vb=b[sortKey];
            if(va==null) return 1;
            if(vb==null) return -1;
            if(typeof va==="string"){
                va=va.toUpperCase(); vb=vb.toUpperCase();
                if(va<vb) return -1*sortDir;
                if(va>vb) return 1*sortDir;
                return 0;
            }
            if(va<vb) return -1*sortDir;
            if(va>vb) return 1*sortDir;
            return 0;
        });
    }

    for(var i=0;i<arr.length;i++){
        var r=arr[i];
        var tr=document.createElement("tr");

        addCell(tr,r.symbol);
        addCell(tr,fmt(r.last));
        addCell(tr,fmt(r.bid));
        addCell(tr,fmt(r.ask));
        addCell(tr,fmt(r.spread));

        addDelta(tr,r.d1);
        addDelta(tr,r.d2);
        addDelta(tr,r.d3);
        addDelta(tr,r.d5);
        addDelta(tr,r.d10);
        addDelta(tr,r.d15);
        addDelta(tr,r.d30);

        addCell(tr,r.v1);
        addCell(tr,r.v3);
        addCell(tr,r.v5);

        tb.appendChild(tr);
    }
}

function addCell(tr,val){
    var td=document.createElement("td");
    td.textContent = (val==null?"-":val);
    tr.appendChild(td);
}

function addDelta(tr,val){
    var td=document.createElement("td");
    if(val==null){
        td.textContent="-";
        td.className="delta neutral";
    } else {
        td.textContent = fmt(val);
        if(val>0) td.className="delta positive";
        else if(val<0) td.className="delta negative";
        else td.className="delta neutral";
    }
    tr.appendChild(td);
}

function fmt(v){
    if(v==null) return "-";
    var n=Number(v);
    if(isNaN(n)) return "-";
    return n.toFixed(4);
}

function setupSort(){
    var ths=document.querySelectorAll("#tbl thead th");
    for(var i=0;i<ths.length;i++){
        ths[i].onclick=function(){
            var k=this.getAttribute("data-k");
            if(sortKey===k){
                sortDir=-sortDir;
            } else {
                sortKey=k;
                sortDir=1;
            }
            render();
        };
    }
}

setupSort();
