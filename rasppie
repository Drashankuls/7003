<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>Top 100 Gainers Dashboard</title>
    <link rel="stylesheet" href="/static/dashboard.css">
</head>
<body>
    <h1>Top 100 Gainers (Live)</h1>
    <div id="last-update">Last update: --</div>
    <div class="table-container">
        <table id="gainers-table">
            <thead>
                <tr>
                    <th data-key="symbol">Symbol</th>
                    <th data-key="last">Last</th>
                    <th data-key="bid">Bid</th>
                    <th data-key="ask">Ask</th>
                    <th data-key="spread">Spread</th>
                    <th data-key="d1">Δ1m</th>
                    <th data-key="d2">Δ2m</th>
                    <th data-key="d3">Δ3m</th>
                    <th data-key="d5">Δ5m</th>
                    <th data-key="d10">Δ10m</th>
                    <th data-key="d15">Δ15m</th>
                    <th data-key="d30">Δ30m</th>
                    <th data-key="v1">Vol1m</th>
                    <th data-key="v3">Vol3m</th>
                    <th data-key="v5">Vol5m</th>
                </tr>
            </thead>
            <tbody>
                <!-- Filled by JS -->
            </tbody>
        </table>
    </div>
    <script src="/static/dashboard.js"></script>
</body>
</html>
